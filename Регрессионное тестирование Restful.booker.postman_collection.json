              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Статус 200 OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Вернулся bookingid\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.property(\"bookingid\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Эталонные данные сохранены корректно\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.booking.firstname).to.eql(\"Reference\");\r",
                  "    pm.expect(json.booking.totalprice).to.eql(500);\r",
                  "});\r",
                  "\r",
                  "// Сохраняем id эталонной брони ОТДЕЛЬНОЙ переменной\r",
                  "const json = pm.response.json();\r",
                  "pm.environment.set(\"reference_booking_id\", json.bookingid);\r",
                  "console.log(\"Эталонная бронь создана, id:\", json.bookingid);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
