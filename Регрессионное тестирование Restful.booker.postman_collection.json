    {
      "name": "02 Основные сценарии",
      "item": [
        {
          "name": "Создание пользователя",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const firstNames = [\"Alice\", \"Bob\", \"Clara\", \"David\", \"Elena\"];\r",
                  "const lastNames  = [\"Smith\", \"Johnson\", \"Brown\", \"Davis\", \"Wilson\"];\r",
                  "\r",
                  "const firstName = firstNames[Math.floor(Math.random() * firstNames.length)];\r",
                  "const lastName  = lastNames[Math.floor(Math.random() * lastNames.length)];\r",
                  "const price = Math.floor(Math.random() * 900) + 100;\r",
                  "\r",
                  "pm.environment.set(\"gen_firstname\", firstName);\r",
                  "pm.environment.set(\"gen_lastname\", lastName);\r",
                  "pm.environment.set(\"gen_price\", price);\r",
                  "\r",
                  "console.log(\"Создаём бронь:\", firstName, lastName, \"цена:\", price);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Статус 200 OK\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Вернулся bookingid\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.property(\"bookingid\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Имя совпадает с отправленным\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.booking.firstname).to.eql(pm.environment.get(\"gen_firstname\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Цена совпадает с отправленной\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.booking.totalprice).to.eql(Number(pm.environment.get(\"gen_price\")));\r",
                  "});\r",
                  "\r",
                  "// Сохраняем id для обновления и удаления\r",
                  "const json = pm.response.json();\r",
                  "pm.environment.set(\"booking_id\", json.bookingid);\r",
                  "console.log(\"Создана бронь с id:\", json.bookingid);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
